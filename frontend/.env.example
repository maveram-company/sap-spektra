# SAP Spektra Frontend — Environment
# Last verified against docker-compose.yml: 2026-03-17
VITE_API_URL=http://localhost:3001/api

# Agent installer download base URL (optional)
# VITE_AGENT_RELEASES_URL=https://releases.spektra.maveram.com/agent/latest

# Operational mode: REAL | FALLBACK | MOCK (default: FALLBACK)
# REAL — all data from live backend API
# FALLBACK — tries real API, falls back to mock on failure
# MOCK — simulated data, no backend needed
# VITE_OPERATIONAL_MODE=FALLBACK

# AWS Cognito (optional — only for production auth)
# VITE_COGNITO_REGION=us-east-1
# VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_CLIENT_ID=
