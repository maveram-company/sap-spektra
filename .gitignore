# ── Dependencies ──
node_modules/

# ── Build output ──
dist/
build/
*.tsbuildinfo
out/

# ── Environment & secrets ──
*.env
.env.*
!*.env.example

# ── OS artifacts ──
.DS_Store
Thumbs.db
__MACOSX/
._*

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
*.iml

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Archives & binaries ──
*.zip
*.tar.gz
*.tgz
*.rar
*.7z

# ── Test / Coverage ──
coverage/
.nyc_output/
junit.xml
test-results/

# ── Deprecated directories (keep only DEPRECATED.md markers) ──
setup/*
!setup/DEPRECATED.md
dashboard/*
!dashboard/DEPRECATED.md

# ── Misc ──
.cache/
*.pid
tmp/
temp/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# ── Terraform (infra/aws) ──
*.tfstate
*.tfstate.backup
.terraform/
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
